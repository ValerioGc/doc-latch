{
  "bundle": {
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "languages": ["English", "Italian", "French", "German"],
        "displayLanguageSelector": true,
        "installerHooks": "nsis/hooks.nsh",
        "customLanguageFiles": {
          "Italian": "nsis/Italian.nsh"
        }
      }
    },
    "resources": {
      "pdfium-bin/windows/pdfium.dll": "pdfium.dll"
    }
  }
}
